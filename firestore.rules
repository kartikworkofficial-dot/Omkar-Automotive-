rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return request.auth.token.email == "rethinkbharatofficial@gmail.com" && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        isAdminEmail()
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.role in ['admin', 'user'] &&
             data.email is string;
    }

    function isValidBlog(data) {
      return data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.authorId is string &&
             data.published is bool;
    }

    function isValidBooking(data) {
      return data.firstName is string && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.firstName is string && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.message is string && data.message.size() < 5000 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'user') ||
        isAdmin() ||
        (isAdminEmail() && request.resource.data.role == 'admin')
      );
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create: if isAdmin() && isValidBlog(request.resource.data);
      allow update: if isAdmin() && isValidBlog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidBooking(request.resource.data);
    }

    match /messages/{messageId} {
      allow read, delete: if isAdmin();
      allow create: if isValidMessage(request.resource.data);
    }
  }
}
